<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup-/Transfer-Regeln (API 31+).
   Ausgeschlossen werden alle Datenquellen, die mit dem gerätegebundenen AndroidKeyStore-
   Schlüssel verschlüsselte Werte enthalten (CryptoManager). Solche Daten ließen sich auf einem
   anderen Gerät ohnehin nicht entschlüsseln und schützen so sensible Inhalte
   (ausgeblendete Apps, Suchverlauf, App-Nutzung, Gesten-Pakete) vor Cloud-/Transfer-Leaks.
   Unsensible Konfiguration (Favoriten, Ordner, Icon-Mappings) wird weiterhin gesichert.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/settings.preferences_pb" />
        <exclude domain="file" path="datastore/search_suggestions.preferences_pb" />
        <exclude domain="sharedpref" path="return_origin_store.xml" />
        <exclude domain="sharedpref" path="icon_cache_meta.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/settings.preferences_pb" />
        <exclude domain="file" path="datastore/search_suggestions.preferences_pb" />
        <exclude domain="sharedpref" path="return_origin_store.xml" />
        <exclude domain="sharedpref" path="icon_cache_meta.xml" />
    </device-transfer>
</data-extraction-rules>
