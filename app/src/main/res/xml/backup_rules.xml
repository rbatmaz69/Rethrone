<?xml version="1.0" encoding="utf-8"?>
<!--
   Auto-Backup-Regeln für Geräte vor API 31 (Android 11 und älter).
   Schließt dieselben verschlüsselten/sensiblen Datenquellen wie data_extraction_rules.xml aus:
   mit dem gerätegebundenen AndroidKeyStore-Schlüssel verschlüsselte Werte sind nach einem
   Restore auf einem anderen Gerät nicht entschlüsselbar und werden daher nicht gesichert.
-->
<full-backup-content>
    <exclude domain="file" path="datastore/settings.preferences_pb" />
    <exclude domain="file" path="datastore/search_suggestions.preferences_pb" />
    <exclude domain="sharedpref" path="return_origin_store.xml" />
    <exclude domain="sharedpref" path="icon_cache_meta.xml" />
</full-backup-content>
