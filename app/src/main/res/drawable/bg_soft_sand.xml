<?xml version="1.0" encoding="utf-8"?>
<!--
  Hintergrundbild für das Standard-Theme „Tulpe".
  Einfarbige Fläche „Sonnen-Creme" (#FFE6A7) für eine warme, aufgeräumte Startseite.
  Die Tulpen-Silhouette wird separat als zentriertes, warm getöntes Hero-Motiv über diese
  Fläche gelegt (siehe ColorTheme.heroImageRes / heroTint / SystemWallpaperView).
  Heller, warmer Ton bleibt top lesbar für Uhr/Datum in dunkler Schrift.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="360dp"
    android:height="720dp"
    android:viewportWidth="1080"
    android:viewportHeight="2160">

    <!-- Voll-Rechteck, einfarbig (Sonnen-Creme, volle Deckkraft) -->
    <path
        android:pathData="M0,0 L1080,0 L1080,2160 L0,2160 Z"
        android:fillColor="#FFFFE6A7" />

</vector>
