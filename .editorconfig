# EditorConfig – einheitlicher Code-Stil fuer Rethrone.
# Wird von IDEs und von detekt-formatting (ktlint-Wrapper) gelesen.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
max_line_length = 140
# Kotlin Official Style (siehe gradle.properties: kotlin.code.style=official)
ktlint_code_style = ktlint_official
# Wildcard-Importe sind in einigen UI-Dateien bewusst genutzt (vgl. detekt.yml).
ktlint_standard_no-wildcard-imports = disabled

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
